# [user] セクションは .gitconfig.local に記載（git 管理外）
# email, name, signingkey を設定してください
[include]
	path = ~/.gitconfig.local

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    plus-style = "syntax #012800"
    minus-style = "syntax #340001"
    syntax-theme = Monokai Extended
    navigate = true

[interactive]
    diffFilter = delta --color-only
